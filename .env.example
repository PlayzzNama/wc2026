# Telegram Bot Token (from @BotFather)
BOT_TOKEN=8977354914:AAFrmrKNnZC9fxnRDyvtIlPvj6-82uOKsPg

# Comma-separated list of Telegram user IDs who are admins (Ivan's ID should be here)
# To find your ID, start a chat with @userinfobot or open the mini-app inside Telegram and check console / header text
ADMIN_IDS=948806223

# Public URL of your hosted mini-app (required for production WebApp button and real use)
# Example: https://wc2026-predictor.vercel.app
WEBAPP_URL=https://your-app-url-here.com

# === For production on Render/Railway etc. (to avoid polling conflicts) ===
# Set this to the PUBLIC URL of your BACKEND service (the one running server/server.cjs)
# Example: https://your-backend.onrender.com
# Then the bot will use webhooks instead of polling.
WEBHOOK_URL=

# Server port
PORT=3001

# For development, the frontend will call this. In production the same origin or configure.
# You usually don't need to change API_URL for the frontend (it auto-detects).

# === IMPORTANT FOR PRODUCTION (Netlify / Vercel etc.) ===
# If you deploy the frontend to Netlify/Vercel, you MUST set this to your backend URL
# Example: VITE_API_URL=https://your-backend.onrender.com
# VITE_API_URL=
